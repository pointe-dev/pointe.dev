# Staging environment — copy to `.env.staging` on the server (/opt/pointe) and fill in.
# Mirrors .env.prod but fully ISOLATED. Never point any of these at prod data.
# See docs/STAGING.md for the one-time setup (DNS, database, Caddy).

# ── LLM ─────────────────────────────────────────────────────────────────────
# Sharing the prod key is fine — it's just API calls, no data isolation concern
# (it does spend budget, same as the prod smoke).
ANTHROPIC_API_KEY=sk-ant-REPLACE

# ── Postgres ────────────────────────────────────────────────────────────────
# SAME server, SEPARATE database. Reuse the prod `pointe` user + password, but
# the `pointe_staging` database (create it once — see docs/STAGING.md).
# The password is in /opt/pointe/secrets/pg_password.txt on the server.
DATABASE_URL=postgres://pointe:REPLACE_WITH_PG_PASSWORD@pointe-postgres:5432/pointe_staging

# ── Public URL ──────────────────────────────────────────────────────────────
# Drives the email confirm links — must be the staging host, not prod.
BASE_URL=https://staging.pointe.dev

# ── Auth ────────────────────────────────────────────────────────────────────
# Its OWN secret so a staging token is invalid on prod and vice-versa.
# Generate: openssl rand -hex 32
SESSION_SECRET=REPLACE_WITH_A_DISTINCT_RANDOM_SECRET

# ── Stripe (TEST keys only) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_test_REPLACE

# ── Deliberately UNSET for isolation (leave absent) ─────────────────────────
#   N8N_API_KEY    → staging never triggers a prod n8n workflow
#   RESEND_API_KEY → confirm links are logged, no real email leaves the box
#   OWNER_EMAIL    → no owner notifications from staging
#   LANGFUSE_*     → no pollution of prod observability traces
#   QDRANT_URL     → embeddings stay disabled (cf project-qdrant-disabled)
