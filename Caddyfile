# pointe.dev reverse proxy
# Caddy handles TLS automatically via Let's Encrypt.

go.pointe.dev {
    reverse_proxy backend:3001 {
        lb_try_duration 15s
        lb_try_interval 300ms
        health_uri /
        health_interval 10s
        health_timeout 5s
    }
}

n8n.pointe.dev {
    reverse_proxy n8n:5678
}

# Ephemeral per-PR staging backend (see docker-compose.staging.yml).
# Returns 502 when staging is down — expected; prod hosts are unaffected.
staging.pointe.dev {
    reverse_proxy pointe-backend-staging:3001
}
